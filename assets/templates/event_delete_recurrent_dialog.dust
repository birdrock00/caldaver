<div id="event_delete_dialog">

{?readable_dates}
{! [E19] Show the date of the instance the user is acting on so it's clear
   which event will be removed by "this repetition" vs "all repetitions". !}
<p class="recurrent-dialog-date"><strong>{readable_dates}</strong></p>
{/readable_dates}

{?first_instance}
<p>{@i18n type="messages" name="info_delete_recurrent_event_first_instance"/}</p>
{:else}
<p>{@i18n type="messages" name="info_delete_recurrent_event"/}</p>
{/first_instance}

</div>
